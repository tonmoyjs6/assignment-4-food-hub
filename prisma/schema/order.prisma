
model Order{
    id String @id @default(uuid())
    userInfo User @relation(fields: [userId],references: [id])
    userId String
    providerInfo ProviderProfile @relation(fields: [providerId],references: [id])
    providerId String
    totalAmount Int @default(0)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    orderStatus status @default(PREPARING)

    orderItems OrderItem[]

    checkouts Checkout[]
}



enum status{
    PREPARING   
    READY
    DELIVERED   
}