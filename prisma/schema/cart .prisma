

model Cart {
    id          String     @id @default(uuid())
    userInfo    User       @relation(fields: [userId], references: [id])
    userId      String     @unique 
    cartStatus  CartStatus @default(ACTIVE)
    createdAt   DateTime   @default(now())
    updatedAt   DateTime   @updatedAt

    cartItems   CartItem[]
    checkout    Checkout?
}

model CartItem {
    id        String   @id @default(uuid())
    cartInfo  Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
    cartId    String
    mealInfo  Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)
    mealId    String
    quantity  Int      @default(1)
    price     Int      
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

enum CartStatus {
    ACTIVE      
    CHECKED_OUT     
    ABANDONED   
}
